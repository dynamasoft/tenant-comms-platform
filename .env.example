# Copy this file to .env and fill in your key.
# NEVER commit your real .env (it is gitignored).

# Gemini API via Google AI Studio (default, simplest path).
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-api-key-here

# Alternatively, use Vertex AI (for Google Cloud deployment).
# Comment out GEMINI_API_KEY above and uncomment these:
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=global
